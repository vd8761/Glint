# =============================================================================
#  Glint — environment
# =============================================================================
#  The server validates all of this at boot (lib/env.ts) and refuses to start if
#  a secret is missing, too short, or is one of the hardcoded defaults that used
#  to ship in this repository. There are no fallbacks.
#
#  Generate the four secrets below with:
#      npm run secrets:generate
# =============================================================================

# ---- Database ---------------------------------------------------------------
# Local:  postgresql://postgres:postgres@localhost:5432/glint
# Neon:   append ?sslmode=require and use the -pooler host for serverless.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/glint"
DATABASE_POOL_MAX="10"

# ---- Secrets (required, min 32 chars; IP_HASH_SALT min 16) ------------------
# JWT_SECRET       signs session tokens.
# CERT_SIGNING_KEY signs certificate issuance facts. MUST differ from JWT_SECRET.
#                  Rotating it invalidates every certificate signature ever issued.
# IP_HASH_SALT     salts the one-way hash of visitor IPs in the audit log.
# CRON_SECRET      bearer token for POST /api/internal/email/drain.
JWT_SECRET=""
CERT_SIGNING_KEY=""
IP_HASH_SALT=""
CRON_SECRET=""

# ---- Application ------------------------------------------------------------
NODE_ENV="development"
PORT="3001"
# Required in production. Used to build the /c/<id> links that go out by email.
APP_URL="http://localhost:3001"
# Comma-separated. Leave empty for same-origin only, which is what the SPA needs.
ALLOWED_ORIGINS=""

# ---- Auth tuning ------------------------------------------------------------
JWT_TTL="8h"
BCRYPT_ROUNDS="12"
MAX_FAILED_LOGINS="8"
LOCKOUT_MINUTES="15"

# ---- Seeding ----------------------------------------------------------------
# `npm run db:seed` generates and prints a strong password when this is unset.
ADMIN_EMAIL="admin@glint.local"
ADMIN_PASSWORD=""

# ---- Email ------------------------------------------------------------------
# MAIL_FROM is the envelope sender for every outbound message. There is no
# fallback: if a transport is configured and MAIL_FROM is not set, the server
# refuses to start. Its domain must be the one verified with your provider —
# a workspace's own sender_email is rewritten onto it if it differs.
#
# Set this even without a transport: new workspaces inherit it as their default
# sender, and it is what recipients will see.
MAIL_FROM="no-reply@originbi.com"
MAIL_FROM_NAME="Glint Credentials"
MAIL_CC=""
# "true" ignores each workspace's own sender and always sends as MAIL_FROM.
MAIL_FORCE_FROM="false"

# Transport. Leave blank and issuance mail is recorded with status='simulated'
# and never delivered — useful locally, and never silently mistaken for success.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""

# Setting RESEND_API_KEY switches the transport to smtp.resend.com:465.
RESEND_API_KEY=""

# ---- AI template generation (optional) --------------------------------------
GEMINI_API_KEY=""
