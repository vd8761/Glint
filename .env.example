# Database Settings
DATABASE_URL="postgresql://user:password@localhost:5432/dbname?sslmode=require"

# AI Integration
GEMINI_API_KEY="your_gemini_api_key_here"

# Authentication
JWT_SECRET="your_secure_random_jwt_secret_here"
ADMIN_SECRET_KEY="your_secure_admin_key_here"

# SMTP Production Configurations
SMTP_HOST="smtp.example.com"
SMTP_PORT="465"
SMTP_USER="smtp_user"
SMTP_PASS="smtp_password"
SMTP_FROM="no-reply@yourdomain.com"
SMTP_FROM_NAME="Glint Credentials"
SMTP_CC="admin@yourdomain.com"

# Application Settings
APP_URL="https://your-production-url.com"
NODE_ENV="development"

# Resend API Settings
RESEND_API_KEY="your_resend_api_key_here"
RESEND_FROM_EMAIL="no-reply@yourdomain.com"

